{
  "entities": {
    "User": {
      "title": "User",
      "description": "Registered patient or administrator user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The unique user ID matching request.auth.uid" },
        "name": { "type": "string", "description": "Full name of the user" },
        "email": { "type": "string", "format": "email", "description": "Email address of the user" },
        "role": { "type": "string", "enum": ["patient", "admin"], "description": "Role of the user" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the user registered" }
      },
      "required": ["uid", "name", "email", "role", "createdAt"]
    },
    "Doctor": {
      "title": "Doctor",
      "description": "Hospital medical doctor profile",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique identifier of the doctor" },
        "name": { "type": "string", "description": "Full name of the doctor" },
        "specialty": { "type": "string", "description": "Doctor's specialization" },
        "department": { "type": "string", "description": "Department code or name" },
        "experience": { "type": "integer", "description": "Years of experience" },
        "education": { "type": "string", "description": "Educational credentials" },
        "bio": { "type": "string", "description": "Brief biography" },
        "avatar": { "type": "string", "description": "Avatar image URL or placeholder name" },
        "availability": { "type": "array", "description": "Days or slots when available" }
      },
      "required": ["id", "name", "specialty", "department", "experience"]
    },
    "Appointment": {
      "title": "Appointment",
      "description": "Medical appointment booking details",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Appointment ID" },
        "patientId": { "type": "string", "description": "User ID of the patient" },
        "patientName": { "type": "string", "description": "Name of the patient" },
        "patientEmail": { "type": "string", "description": "Email of the patient" },
        "doctorId": { "type": "string", "description": "ID of the doctor" },
        "doctorName": { "type": "string", "description": "Name of the doctor" },
        "doctorSpecialty": { "type": "string", "description": "Specialty of the doctor" },
        "date": { "type": "string", "format": "date", "description": "Appointment date" },
        "time": { "type": "string", "description": "Appointment time slot" },
        "status": { "type": "string", "enum": ["pending", "confirmed", "completed", "cancelled"], "description": "Current status" },
        "notes": { "type": "string", "description": "Patient symptoms or notes" },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["id", "patientId", "patientName", "patientEmail", "doctorId", "doctorName", "doctorSpecialty", "date", "time", "status", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Patient medical report or test results documentation",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Report ID" },
        "patientId": { "type": "string", "description": "User ID of the patient" },
        "patientName": { "type": "string", "description": "Name of the patient" },
        "title": { "type": "string", "description": "Title or name of the test/report" },
        "date": { "type": "string", "format": "date", "description": "Report date" },
        "fileUrl": { "type": "string", "description": "URL or base64 or description of file" },
        "fileType": { "type": "string", "description": "Mime type or descriptor" },
        "fileSize": { "type": "string", "description": "Human readable size" },
        "notes": { "type": "string", "description": "Notes or diagnostic findings" },
        "uploadedAt": { "type": "string", "format": "date-time", "description": "Upload timestamp" }
      },
      "required": ["id", "patientId", "patientName", "title", "date", "fileUrl", "uploadedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User profile collection"
    },
    "doctors/{doctorId}": {
      "schema": "Doctor",
      "description": "Doctors profile collection"
    },
    "appointments/{appointmentId}": {
      "schema": "Appointment",
      "description": "Appointments collection"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Medical reports collection"
    }
  }
}
