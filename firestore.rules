rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- GLOBAL HELPERS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && (request.auth.token.email_verified == true || request.auth.token.email != null);
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'keerthanasunkari00@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY SPECIFIC VALIDATION HELPERS ---
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.email is string && data.email.size() <= 200 &&
             data.role is string && (data.role == 'patient' || data.role == 'admin') &&
             data.createdAt is string;
    }

    function isValidDoctor(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.name is string && data.name.size() <= 200 &&
             data.specialty is string && data.specialty.size() <= 200 &&
             data.department is string && data.department.size() <= 200 &&
             data.experience is int &&
             data.education is string && data.education.size() <= 500 &&
             data.bio is string && data.bio.size() <= 2000 &&
             data.avatar is string && data.avatar.size() <= 2000 &&
             data.availability is list && data.availability.size() <= 7;
    }

    function isValidAppointment(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.patientId is string && data.patientId.size() <= 128 &&
             data.patientName is string && data.patientName.size() <= 200 &&
             data.patientEmail is string && data.patientEmail.size() <= 200 &&
             data.doctorId is string && data.doctorId.size() <= 128 &&
             data.doctorName is string && data.doctorName.size() <= 200 &&
             data.doctorSpecialty is string && data.doctorSpecialty.size() <= 200 &&
             data.date is string && data.date.size() <= 32 &&
             data.time is string && data.time.size() <= 32 &&
             data.status is string && (data.status == 'pending' || data.status == 'confirmed' || data.status == 'completed' || data.status == 'cancelled') &&
             data.notes is string && data.notes.size() <= 5000 &&
             data.createdAt is string;
    }

    function isValidReport(data) {
      return data.id is string && data.id.size() <= 128 &&
             data.patientId is string && data.patientId.size() <= 128 &&
             data.patientName is string && data.patientName.size() <= 200 &&
             data.title is string && data.title.size() <= 200 &&
             data.date is string && data.date.size() <= 32 &&
             data.fileUrl is string && data.fileUrl.size() <= 10000 &&
             data.fileType is string && data.fileType.size() <= 128 &&
             data.fileSize is string && data.fileSize.size() <= 128 &&
             data.notes is string && data.notes.size() <= 5000 &&
             data.uploadedAt is string;
    }

    // --- MATCH BLOCKS ---

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isEmailVerified() && (isOwner(userId) || isAdmin());
      allow list: if isEmailVerified() && isAdmin();
      
      allow create: if isEmailVerified() && isOwner(userId) && isValidUser(incoming()) && (incoming().role == 'patient' || (incoming().role == 'admin' && request.auth.token.email == 'keerthanasunkari00@gmail.com'));
      
      allow update: if isEmailVerified() && (
        (isOwner(userId) && isValidUser(incoming()) && incoming().role == existing().role && incoming().uid == existing().uid) ||
        isAdmin()
      );
      
      allow delete: if isEmailVerified() && isAdmin();
    }

    // 2. Doctors Collection
    match /doctors/{doctorId} {
      allow read: if true; // Public read allowed for browsing
      allow create, update: if isEmailVerified() && isAdmin() && isValidDoctor(incoming());
      allow delete: if isEmailVerified() && isAdmin();
    }

    // 3. Appointments Collection
    match /appointments/{appointmentId} {
      allow get: if isEmailVerified() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow list: if isEmailVerified() && (resource.data.patientId == request.auth.uid || isAdmin());
      
      allow create: if isEmailVerified() && incoming().patientId == request.auth.uid && isValidAppointment(incoming()) && incoming().status == 'pending';
      
      allow update: if isEmailVerified() && (
        // Patient can cancel their own appointment
        (resource.data.patientId == request.auth.uid && 
         incoming().patientId == resource.data.patientId && 
         incoming().status == 'cancelled' && 
         incoming().diff(existing()).affectedKeys().hasOnly(['status'])) ||
        isAdmin()
      );
      
      allow delete: if isEmailVerified() && isAdmin();
    }

    // 4. Reports Collection
    match /reports/{reportId} {
      allow get: if isEmailVerified() && (resource.data.patientId == request.auth.uid || isAdmin());
      allow list: if isEmailVerified() && (resource.data.patientId == request.auth.uid || isAdmin());
      
      allow create: if isEmailVerified() && incoming().patientId == request.auth.uid && isValidReport(incoming());
      allow update: if isEmailVerified() && isAdmin();
      allow delete: if isEmailVerified() && (resource.data.patientId == request.auth.uid || isAdmin());
    }
  }
}
